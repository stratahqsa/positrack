# POSX Reports dashboard — environment (copy to .env.local for dev; set the
# same keys in Vercel → positrack-reports → Settings → Environment Variables
# for production). NEVER commit real secrets.

# Shared viewer access code (any string) — the /login gate. Sessions are
# HMAC-signed with this value, so rotating it logs everyone out.
ACCESS_CODE=

# SEPARATE admin code for /admin (schedule editor + Refresh Now). Deliberately
# not the viewer code: everyone has the viewer PIN; only schedule owners get
# this. Rotating it invalidates only admin sessions.
ADMIN_CODE=

# Secret Vercel Blob base for the snapshot: "<blob-base>/<SNAPSHOT_SECRET>".
# lib/data.ts fetches `${SNAPSHOT_DATA_URL}/latest.json`; lib/schedule-config
# reads/writes `${SNAPSHOT_DATA_URL}/schedule.json` (same secret prefix).
# Unset in dev → local files under dashboard/data/ are used instead.
SNAPSHOT_DATA_URL=

# Blob write token for saving schedule.json from /admin. In production this is
# auto-injected by connecting the Blob store to the Vercel project (Storage →
# Connect Project); only set manually for local testing of schedule writes.
BLOB_READ_WRITE_TOKEN=

# Fine-grained GitHub PAT (repo stratahqsa/positrack only, Actions: read &
# write) — lets /api/cron/refresh and /admin dispatch the snapshot workflow
# and list its runs. Created 2026-07-23; renew before expiry (1y).
GH_DISPATCH_TOKEN=

# Vercel Cron auth: Vercel automatically sends `Authorization: Bearer
# $CRON_SECRET` on cron invocations when this env var exists; the
# /api/cron/refresh route rejects anything else. Generate: `openssl rand -hex 32`.
CRON_SECRET=
