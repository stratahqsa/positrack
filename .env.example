# POSX Control Tower — repo-root environment (scripts/ tooling)
# Copy to `.env.local` for local dev, or export directly. NEVER commit real secrets.
# (This is separate from web/.env.example and dashboard/.env.local, which cover
# those apps' own login-gate ACCESS_CODE.)

# --- AI briefing (scripts/ai_brief.mjs) --------------------------------------
# Optional, additive feature: a short 3-part exec brief baked into
# web/data/latest.json's `ai_brief` field by the hourly Snapshot workflow
# (.github/workflows/snapshot.yml). Fully fail-soft: with AI_API_KEY unset
# (and no --mock/AI_BRIEF_MOCK), scripts/ai_brief.mjs logs a warning and
# leaves latest.json untouched — nothing else in the snapshot pipeline
# depends on this being configured.

# Any OpenAI-compatible chat-completions endpoint. Default target is
# OpenRouter, which fronts many providers (including DeepSeek and Anthropic
# models) behind one OpenAI-compatible API — swap AI_MODEL to change provider
# with no code change.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
# e.g. deepseek/deepseek-chat (cheap default) or an Anthropic model id
# available through your gateway, such as anthropic/claude-sonnet-4.5.
AI_MODEL=deepseek/deepseek-chat

# PRIVACY (fail-closed by default — leave both unset until a deliberate
# decision is made about what may egress to a third-party LLM):
#   AI_SEND_REAL_NAMES=1   sends real staff names instead of pseudonyms
#                           (P1, P2, ...) for the "most behind" ranking.
#   AI_SEND_SUMMARIES=1    sends bug free-text summaries (may contain
#                           customer-reported detail) instead of omitting them.
# See scripts/lib/distill-brief-input.mjs for exactly what each flag widens.
AI_SEND_REAL_NAMES=
AI_SEND_SUMMARIES=

# Local/dev/test only — never set in CI. Points scripts/ai_brief.mjs at a
# canned JSON response instead of calling the model at all (no key, no
# network, no `openai` package import). Same effect as `--mock <file>` on the
# CLI. See scripts/fixtures/mock-brief.json for the expected shape.
AI_BRIEF_MOCK=
