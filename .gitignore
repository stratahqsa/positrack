# Secrets / tokens — NEVER commit
*.env
/tmp/yt*.env
yt.env
*.token
.env.*
# ...except *.env.example templates (placeholder values only, no real
# secrets) — these are meant to be committed so contributors know which vars
# to set. Matches the existing tracked web/.env.example convention.
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# Build artifacts
dist/
*.skill

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local engine cache (CLI shell only)
yt_projects*.json

# OMC build-process state (specs/plans kept on disk, not in product history)
.omc/

# Control Tower snapshot data is published to the `snapshot-latest` GitHub Release
# (uploaded nightly), not committed. Local `python3 scripts/snapshot.py` output
# stays untracked.
web/data/

# Claude Code local project config (personal tooling; the committed web/.claude/ is
# separate and unaffected by this root-anchored rule).
/.claude/
